{
  "manifest_version": 3,
  "name": "FB Voice Downloader",
  "version": "1.0.0",
  "description": "Download voice messages from Facebook and Messenger",
  "permissions": ["downloads", "scripting"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://www.messenger.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://www.messenger.com/*"],
      "js": ["dist/content/index.js"],
      "css": ["dist/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "dist/popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}